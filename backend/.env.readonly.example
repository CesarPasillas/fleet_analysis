MODEL_PATH=app/ml/artifacts/route_model.keras
MODEL_METADATA_PATH=app/ml/artifacts/metadata.json
DEFAULT_TRAINING_DATA=data/routes_training.csv
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Read-only external source profile (example)
# Use absolute paths provided by the data owner
DATA_POS_DIR=/mnt/read-only/telemetry/pos
DATA_POS_GLOB_PATTERN=pos*.csv
# Optional override for snapshot builder (has highest priority)
# DATA_POS_GLOB=/mnt/read-only/telemetry/pos/*.parquet
DATA_EVENTTYPE_CSV=/mnt/read-only/catalogs/EventType.csv
